+/* ------------------------------------------------------------------------- */
+/* Dispatch stubs.  Phase 1: always decline reads, ignore writes.  Future
+ * phases switch on slots[chipno].kind and call into per-chip modules.       */
+/* ------------------------------------------------------------------------- */
+
+int sid_variant_try_read(int chipno, uint16_t reg, uint8_t *out)
+{
+    sid_variant_slot_t *slot;
+    if (chipno < 0 || chipno >= SID_VARIANT_NUM_CHIPS) {
+        return 0;
+    }
+    slot = &slots[chipno];
+    switch (slot->kind) {
+    case SID_VARIANT_ARMSID:
+    case SID_VARIANT_ARM2SID:
+        return sid_variant_armsid_try_read(slot, reg, out);
+    case SID_VARIANT_PDSID:
+        return sid_variant_pdsid_try_read(slot, reg, out);
+    case SID_VARIANT_KUNGFUSID_OLD:
+    case SID_VARIANT_KUNGFUSID_NEW:
+        return sid_variant_kungfu_try_read(slot, reg, out);
+    case SID_VARIANT_BACKSID:
+        return sid_variant_backsid_try_read(slot, reg, out);
+    case SID_VARIANT_USID64:
+        return sid_variant_usid64_try_read(slot, reg, out);
+    case SID_VARIANT_SWINU:
+        return sid_variant_swinu_try_read(slot, reg, out);
+    case SID_VARIANT_SWINNANO:
+        return sid_variant_swinnano_try_read(slot, reg, out);
+    case SID_VARIANT_FPGASID_6581:
+    case SID_VARIANT_FPGASID_8580:
+        return sid_variant_fpgasid_try_read(slot, reg, out);
+    case SID_VARIANT_SKPICO_6581:
+    case SID_VARIANT_SKPICO_8580:
+        return sid_variant_skpico_try_read(slot, reg, out);
+    case SID_VARIANT_SIDFX:
+        return sid_variant_sidfx_try_read(slot, reg, out);
+    /* Other variants join here as their personality modules land. */
+    default:
+        return 0;
+    }
+}
+
+void sid_variant_observe_write(int chipno, uint16_t reg, uint8_t val)
+{
+    sid_variant_slot_t *slot;
+    if (chipno < 0 || chipno >= SID_VARIANT_NUM_CHIPS) {
+        return;
+    }
+    slot = &slots[chipno];
+    switch (slot->kind) {
+    case SID_VARIANT_ARMSID:
+    case SID_VARIANT_ARM2SID:
+        sid_variant_armsid_observe_write(slot, reg, val);
+        return;
+    case SID_VARIANT_PDSID:
+        sid_variant_pdsid_observe_write(slot, reg, val);
+        return;
+    case SID_VARIANT_KUNGFUSID_OLD:
+    case SID_VARIANT_KUNGFUSID_NEW:
+        sid_variant_kungfu_observe_write(slot, reg, val);
+        return;
+    case SID_VARIANT_BACKSID:
+        sid_variant_backsid_observe_write(slot, reg, val);
+        return;
+    case SID_VARIANT_USID64:
+        sid_variant_usid64_observe_write(slot, reg, val);
+        return;
+    case SID_VARIANT_SWINU:
+        sid_variant_swinu_observe_write(slot, reg, val);
+        return;
+    case SID_VARIANT_SWINNANO:
+        sid_variant_swinnano_observe_write(slot, reg, val);
+        return;
+    case SID_VARIANT_FPGASID_6581:
+    case SID_VARIANT_FPGASID_8580:
+        sid_variant_fpgasid_observe_write(slot, reg, val);
+        return;
+    case SID_VARIANT_SKPICO_6581:
+    case SID_VARIANT_SKPICO_8580:
+        sid_variant_skpico_observe_write(slot, reg, val);
+        return;
+    case SID_VARIANT_SIDFX:
+        sid_variant_sidfx_observe_write(slot, reg, val);
+        return;
+    default:
+        return;
+    }
+}
+
+void sid_variant_reset_all(void)
+{
+    int i;
+    for (i = 0; i < SID_VARIANT_NUM_CHIPS; i++) {
+        memset(slots[i].state, 0, sizeof(slots[i].state));
+        slots[i].last_write_clk = 0;
+        switch (slots[i].kind) {
+        case SID_VARIANT_ARMSID:
+        case SID_VARIANT_ARM2SID:
+            sid_variant_armsid_reset(&slots[i]);
+            break;
+        case SID_VARIANT_PDSID:
+            sid_variant_pdsid_reset(&slots[i]);
+            break;
+        case SID_VARIANT_KUNGFUSID_OLD:
+        case SID_VARIANT_KUNGFUSID_NEW:
+            sid_variant_kungfu_reset(&slots[i]);
+            break;
+        case SID_VARIANT_BACKSID:
+            sid_variant_backsid_reset(&slots[i]);
+            break;
+        case SID_VARIANT_USID64:
+            sid_variant_usid64_reset(&slots[i]);
+            break;
+        case SID_VARIANT_SWINU:
+            sid_variant_swinu_reset(&slots[i]);
+            break;
+        case SID_VARIANT_SWINNANO:
+            sid_variant_swinnano_reset(&slots[i]);
+            break;
+        case SID_VARIANT_FPGASID_6581:
+        case SID_VARIANT_FPGASID_8580:
+            sid_variant_fpgasid_reset(&slots[i]);
+            break;
+        case SID_VARIANT_SKPICO_6581:
+        case SID_VARIANT_SKPICO_8580:
+            sid_variant_skpico_reset(&slots[i]);
+            break;
+        case SID_VARIANT_SIDFX:
+            sid_variant_sidfx_reset(&slots[i]);
+            break;
+        default:
+            break;
+        }
+    }
+}
