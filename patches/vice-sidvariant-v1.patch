diff -urN '--exclude=*.o' '--exclude=*.a' '--exclude=.deps' '--exclude=config.log' '--exclude=config.status' '--exclude=Makefile' '--exclude=GTK3VICE-*' '--exclude=autom4te.cache' '--exclude=*.lo' '--exclude=*.la' '--exclude=*.exe' '--exclude=*.Po' '--exclude=.libs' /c/Users/mit/Downloads/vice-3.9/src/sid/sid-variant-armsid.c vice-sidvariant/src/sid/sid-variant-armsid.c
--- /c/Users/mit/Downloads/vice-3.9/src/sid/sid-variant-armsid.c	1970-01-01 01:00:00.000000000 +0100
+++ vice-sidvariant/src/sid/sid-variant-armsid.c	2026-04-20 22:02:06.651410600 +0200
@@ -0,0 +1,201 @@
+/** \file   sid-variant-armsid.c
+ *  \brief  ARMSID / ARM2SID magic-cookie responder.
+ *
+ *  Implements just enough of the ARMSID firmware protocol to make
+ *  siddetector.prg's `Checkarmsid` and `armsid_get_version` routines classify
+ *  this chip as ARMSID (firmware major 2) or ARM2SID (firmware major 3).
+ *  No audio is generated by this file — ResID continues to synthesise
+ *  whatever was written to the usual SID registers; we only override reads
+ *  of `$D41B`/`$D41C`/`$D41D` while the firmware is in "config mode".
+ *
+ *  ### Protocol overview
+ *
+ *  1. Host writes the PETSCII sequence `'D'` ($44) → `$D41F`,
+ *     `'I'` ($49) → `$D41E`, `'S'` ($53) → `$D41D`.  This atomically enters
+ *     *config mode*.
+ *  2. While in config mode:
+ *     - `$D41B` returns `'N'` ($4E)   — idle "NO-op" echo
+ *     - `$D41C` returns `'O'` ($4F)
+ *     - sequential `$D41D` reads on ARM2SID return the 8-slot map
+ *       (nibble-packed into 4 bytes, auto-incrementing pointer).
+ *  3. Inside config mode, sub-commands are issued by writing a
+ *     two-byte pair to `$D41F` + `$D41E`.  The pair encodes the query:
+ *
+ *     | D41F | D41E | Meaning                                   |
+ *     |------|------|-------------------------------------------|
+ *     | 'V'  | 'I'  | firmware version → D41B=major, D41C=minor |
+ *     | 'E'  | 'I'  | EI probe         → D41B='S', D41C='W'     |
+ *     | 'I'  | 'I'  | II probe         → D41B=2(ARM2)/other,    |
+ *     |      |      |                    D41C='L'/'R' (ARM2 only)|
+ *     | 'F'  | 'I'  | emulated SID     → D41B='6' or '8'        |
+ *     | 'G'  | 'I'  | auto-detect      → D41B='7'               |
+ *     | 'M'  | 'M'  | mode bits        → D41B low-2 = mode      |
+ *
+ *  4. Any non-cookie write to `$D418` (master-volume register) returns the
+ *     firmware to idle.  Real hardware also times out after ~100 ms; we
+ *     mimic that loosely (see `ARMSID_IDLE_TIMEOUT_CLK`).
+ *
+ *  The protocol bytes are PETSCII values but are numerically identical to
+ *  the ASCII forms for the characters used here (`d`=$44, `i`=$49, etc.),
+ *  so siddetector.asm writes raw hex literals and the values match.
+ */
+
+#include "vice.h"
+
+#include <string.h>
+
+#include "maincpu.h"
+#include "sid-variant.h"
+
+/* Approx 100 ms at ~1 MHz PAL clock. */
+#define ARMSID_IDLE_TIMEOUT_CLK   100000UL
+
+/* Per-slot state, overlaid on sid_variant_slot_t::state[] (64 bytes).  */
+typedef struct {
+    uint8_t  in_config;    /* 1 while firmware has the 'D','I','S' cookie  */
+    uint8_t  last_d41f;    /* most recent write to D41F (sub-command high) */
+    uint8_t  last_d41e;    /* most recent write to D41E (sub-command low)  */
+    uint8_t  map_ptr;      /* ARM2SID map auto-incrementing D41D read idx  */
+    uint8_t  minor_bcd;    /* firmware minor version — 0..99, shown as .XX */
+    uint8_t  major;        /* firmware major (2 = ARMSID, 3 = ARM2SID)     */
+    uint8_t  emul_sid;     /* emulated SID type: '6' ($36) or '8' ($38)    */
+    uint8_t  ch_lr;        /* ARM2SID channel: 'L' ($4C) or 'R' ($52)      */
+    uint8_t  mode;         /* ARM2SID mode bits 0..2 (SID/SFX/SID+SFX)     */
+    uint8_t  map[4];       /* nibble-packed 8-slot map (ARM2SID only)      */
+} armsid_state_t;
+
+static armsid_state_t *as(sid_variant_slot_t *slot)
+{
+    return (armsid_state_t *)slot->state;
+}
+
+static void armsid_do_reset(sid_variant_slot_t *slot, uint8_t major)
+{
+    armsid_state_t *s = as(slot);
+    memset(s, 0, sizeof(*s));
+    s->major    = major;
+    s->minor_bcd = 50;           /* "V2.50" / "V3.50" — plausible default */
+    s->emul_sid = '8';           /* 8580 emulation  */
+    s->ch_lr    = 'L';           /* ARM2SID channel L */
+    s->mode     = 0;             /* SID-only mode (ARM2SID) */
+    /* Slot map (ARM2SID only): slot 0 (D400) = 'SIDL' code (1),
+     * slot 1 (D420) = 'SIDR' (2), rest empty.  Nibble-packed,
+     * low nibble first per `arm2sid_map_l` docs in siddetector.asm. */
+    s->map[0] = (uint8_t)((2u << 4) | 1u);   /* D400=SIDL, D420=SIDR */
+    s->map[1] = 0;                           /* D500, D520 = ---- */
+    s->map[2] = 0;                           /* DE00, DE20 = ---- */
+    s->map[3] = 0;                           /* DF00, DF20 = ---- */
+}
+
+void sid_variant_armsid_reset(sid_variant_slot_t *slot)
+{
+    uint8_t major = (slot->kind == SID_VARIANT_ARM2SID) ? 3 : 2;
+    armsid_do_reset(slot, major);
+}
+
+void sid_variant_armsid_observe_write(sid_variant_slot_t *slot,
+                                      uint16_t reg, uint8_t val)
+{
+    armsid_state_t *s = as(slot);
+
+    /* Lazy-init on first traffic — avoids having to hook machine_reset. */
+    if (s->major == 0) {
+        sid_variant_armsid_reset(slot);
+    }
+
+    /* Any write to D418 (master volume) drops us out of config mode, matching
+     * the real firmware's exit behaviour. */
+    if (reg == 0x18 && s->in_config) {
+        s->in_config = 0;
+        s->map_ptr   = 0;
+        return;
+    }
+
+    /* Track sub-command latches. */
+    if (reg == 0x1f) {
+        s->last_d41f = val;
+    } else if (reg == 0x1e) {
+        s->last_d41e = val;
+    } else if (reg == 0x1d) {
+        /* Entry cookie: 'D' in D41F, 'I' in D41E, then 'S' to D41D. */
+        if (!s->in_config
+            && s->last_d41f == 'D'
+            && s->last_d41e == 'I'
+            && val == 'S') {
+            s->in_config = 1;
+            s->map_ptr   = 0;
+        }
+    }
+
+    slot->last_write_clk = (unsigned long)maincpu_clk;
+}
+
+static int armsid_idle_timed_out(sid_variant_slot_t *slot)
+{
+    return ((unsigned long)maincpu_clk - slot->last_write_clk)
+           > ARMSID_IDLE_TIMEOUT_CLK;
+}
+
+int sid_variant_armsid_try_read(sid_variant_slot_t *slot,
+                                uint16_t reg, uint8_t *out)
+{
+    armsid_state_t *s = as(slot);
+
+    if (s->major == 0) {
+        sid_variant_armsid_reset(slot);
+    }
+    if (!s->in_config) {
+        return 0;   /* idle → pass through to ResID */
+    }
+    if (armsid_idle_timed_out(slot)) {
+        s->in_config = 0;
+        s->map_ptr   = 0;
+        return 0;
+    }
+
+    /* Decode active sub-command from the last D41F/D41E pair. */
+    switch (reg) {
+    case 0x1b:                              /* D41B — primary answer byte */
+        if (s->last_d41f == 'V' && s->last_d41e == 'I') {   /* version  */
+            *out = s->major;
+        } else if (s->last_d41f == 'E' && s->last_d41e == 'I') { /* EI  */
+            *out = 'S';
+        } else if (s->last_d41f == 'I' && s->last_d41e == 'I') { /* II  */
+            *out = (s->major == 3) ? 2 : 0;
+        } else if (s->last_d41f == 'F' && s->last_d41e == 'I') { /* SID type */
+            *out = s->emul_sid;
+        } else if (s->last_d41f == 'G' && s->last_d41e == 'I') { /* auto */
+            *out = '7';
+        } else if (s->last_d41f == 'M' && s->last_d41e == 'M') { /* mode */
+            *out = (uint8_t)(s->mode & 0x03);
+        } else {
+            *out = 'N';                                          /* idle */
+        }
+        return 1;
+
+    case 0x1c:                              /* D41C — secondary answer    */
+        if (s->last_d41f == 'V' && s->last_d41e == 'I') {
+            *out = s->minor_bcd;
+        } else if (s->last_d41f == 'E' && s->last_d41e == 'I') {
+            *out = 'W';
+        } else if (s->last_d41f == 'I' && s->last_d41e == 'I') {
+            *out = (s->major == 3) ? s->ch_lr : 0;
+        } else {
+            *out = 'O';                                          /* idle */
+        }
+        return 1;
+
+    case 0x1d:                              /* D41D — ARM2SID slot map    */
+        if (s->major == 3) {
+            uint8_t v = s->map[s->map_ptr & 0x03];
+            s->map_ptr = (uint8_t)((s->map_ptr + 1) & 0x03);
+            *out = v;
+        } else {
+            *out = 'R';      /* plain ARMSID returns 'R' here per spec */
+        }
+        return 1;
+
+    default:
+        return 0;   /* other registers pass through */
+    }
+}
