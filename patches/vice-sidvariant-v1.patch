--- /c/Users/mit/Downloads/vice-3.9/src/sid/sid-variant.c	1970-01-01 01:00:00.000000000 +0100
+++ vice-sidvariant/src/sid/sid-variant.c	2026-04-21 16:50:41.976017800 +0200
@@ -0,0 +1,390 @@
+/** \file   sid-variant.c
+ *  \brief  Phase 1 skeleton — resource/CLI wiring + no-op dispatcher.
+ *
+ *  This file adds the `SidVariant` string resource family and the
+ *  `-sidvariant` CLI flag family but intentionally ships **no chip
+ *  personality logic yet**.  All variant names are accepted ("none",
+ *  "armsid", "arm2sid", "swinu", "swinnano", "fpgasid6581", "fpgasid8580",
+ *  "pdsid", "kungfusid-old", "kungfusid-new", "backsid", "skpico-8580",
+ *  "skpico-6581", "sidfx", "usid64") but every chip still behaves like plain
+ *  ResID.  Later phases (see docs/ARMSID_PROXY_PLAN.md in the siddetector
+ *  repo) flesh out the per-chip state machines behind `ops->try_read` /
+ *  `ops->observe_write`.
+ */
+
+#include "vice.h"
+
+#include <stdio.h>
+#include <string.h>
+
+#include "cmdline.h"
+#include "lib.h"
+#include "log.h"
+#include "resources.h"
+#include "sid-variant.h"
+#include "types.h"
+#include "util.h"
+
+/* Variant kind enum is declared in sid-variant.h so per-variant modules
+ * can switch on it.  The `known_names[]` table below mirrors the enum. */
+
+static const char * const known_names[SID_VARIANT_COUNT] = {
+    [SID_VARIANT_NONE]           = "none",
+    [SID_VARIANT_ARMSID]         = "armsid",
+    [SID_VARIANT_ARM2SID]        = "arm2sid",
+    [SID_VARIANT_SWINU]          = "swinu",
+    [SID_VARIANT_SWINNANO]       = "swinnano",
+    [SID_VARIANT_FPGASID_6581]   = "fpgasid6581",
+    [SID_VARIANT_FPGASID_8580]   = "fpgasid8580",
+    [SID_VARIANT_PDSID]          = "pdsid",
+    [SID_VARIANT_KUNGFUSID_OLD]  = "kungfusid-old",
+    [SID_VARIANT_KUNGFUSID_NEW]  = "kungfusid-new",
+    [SID_VARIANT_BACKSID]        = "backsid",
+    [SID_VARIANT_SKPICO_8580]    = "skpico-8580",
+    [SID_VARIANT_SKPICO_6581]    = "skpico-6581",
+    [SID_VARIANT_SIDFX]          = "sidfx",
+    [SID_VARIANT_USID64]         = "usid64",
+};
+
+/* sid_variant_slot_t struct is declared in sid-variant.h so per-variant
+ * modules can access `state[]` through `sid_variant_slot(chipno)`. */
+
+static sid_variant_slot_t slots[SID_VARIANT_NUM_CHIPS];
+
+sid_variant_slot_t *sid_variant_slot(int chipno)
+{
+    if (chipno < 0 || chipno >= SID_VARIANT_NUM_CHIPS) {
+        return NULL;
+    }
+    return &slots[chipno];
+}
+
+/* Forward declarations for per-variant handlers. */
+#define VARIANT_DECL(suffix) \
+    extern void sid_variant_##suffix##_observe_write(sid_variant_slot_t *, uint16_t, uint8_t); \
+    extern int  sid_variant_##suffix##_try_read(sid_variant_slot_t *, uint16_t, uint8_t *); \
+    extern void sid_variant_##suffix##_reset(sid_variant_slot_t *)
+VARIANT_DECL(armsid);
+VARIANT_DECL(pdsid);
+VARIANT_DECL(kungfu);
+VARIANT_DECL(backsid);
+VARIANT_DECL(usid64);
+VARIANT_DECL(swinu);
+VARIANT_DECL(swinnano);
+VARIANT_DECL(fpgasid);
+VARIANT_DECL(skpico);
+VARIANT_DECL(sidfx);
+#undef VARIANT_DECL
+
+/* log target set up lazily on first resource set so CLI errors appear cleanly. */
+static log_t variant_log = LOG_DEFAULT;
+
+static sid_variant_kind_t name_to_kind(const char *name)
+{
+    int i;
+    if (name == NULL || *name == '\0') {
+        return SID_VARIANT_NONE;
+    }
+    for (i = 0; i < SID_VARIANT_COUNT; i++) {
+        if (known_names[i] != NULL && strcmp(known_names[i], name) == 0) {
+            return (sid_variant_kind_t)i;
+        }
+    }
+    return SID_VARIANT_COUNT;   /* sentinel = unknown */
+}
+
+/* ------------------------------------------------------------------------- */
+/* Resource setter — one instance, driven per-chip via the void* param which
+ * carries the chip index (0..7).                                            */
+/* ------------------------------------------------------------------------- */
+
+static int set_sid_variant(const char *val, void *param)
+{
+    int chipno = vice_ptr_to_int(param);
+    sid_variant_kind_t k;
+
+    if (chipno < 0 || chipno >= SID_VARIANT_NUM_CHIPS) {
+        return -1;
+    }
+
+    k = name_to_kind(val);
+    if (k == SID_VARIANT_COUNT) {
+        log_error(variant_log,
+                  "Unknown SidVariant%s name '%s'. Known names: "
+                  "none, armsid, arm2sid, swinu, swinnano, fpgasid6581, "
+                  "fpgasid8580, pdsid, kungfusid-old, kungfusid-new, backsid, "
+                  "skpico-8580, skpico-6581, sidfx, usid64.",
+                  (chipno == 0) ? "" : (const char[]){(char)('0' + chipno + 1), 0},
+                  (val != NULL) ? val : "(null)");
+        return -1;
+    }
+
+    if (util_string_set(&slots[chipno].name, (val != NULL) ? val : "none")) {
+        return 0;
+    }
+    slots[chipno].kind = k;
+    memset(slots[chipno].state, 0, sizeof(slots[chipno].state));
+    slots[chipno].last_write_clk = 0;
+    /* Give each variant a chance to initialise defaults in state[] (e.g.
+     * SIDFX's default D41D/D41E values, ARMSID's firmware-major/minor).   */
+    switch (k) {
+    case SID_VARIANT_ARMSID:
+    case SID_VARIANT_ARM2SID:
+        sid_variant_armsid_reset(&slots[chipno]);
+        break;
+    case SID_VARIANT_PDSID:
+        sid_variant_pdsid_reset(&slots[chipno]);
+        break;
+    case SID_VARIANT_KUNGFUSID_OLD:
+    case SID_VARIANT_KUNGFUSID_NEW:
+        sid_variant_kungfu_reset(&slots[chipno]);
+        break;
+    case SID_VARIANT_BACKSID:
+        sid_variant_backsid_reset(&slots[chipno]);
+        break;
+    case SID_VARIANT_USID64:
+        sid_variant_usid64_reset(&slots[chipno]);
+        break;
+    case SID_VARIANT_SWINU:
+        sid_variant_swinu_reset(&slots[chipno]);
+        break;
+    case SID_VARIANT_SWINNANO:
+        sid_variant_swinnano_reset(&slots[chipno]);
+        break;
+    case SID_VARIANT_FPGASID_6581:
+    case SID_VARIANT_FPGASID_8580:
+        sid_variant_fpgasid_reset(&slots[chipno]);
+        break;
+    case SID_VARIANT_SKPICO_6581:
+    case SID_VARIANT_SKPICO_8580:
+        sid_variant_skpico_reset(&slots[chipno]);
+        break;
+    case SID_VARIANT_SIDFX:
+        sid_variant_sidfx_reset(&slots[chipno]);
+        break;
+    default:
+        break;
+    }
+    return 0;
+}
