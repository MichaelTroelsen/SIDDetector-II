+++ vice-sidvariant/src/sid/sid-variant-usid64.c	2026-04-21 06:26:28.608568300 +0200
@@ -0,0 +1,80 @@
+/** \file   sid-variant-usid64.c
+ *  \brief  uSID64 magic-cookie responder.
+ *
+ *  Protocol (per siddetector.asm `checkusid64`):
+ *    Host writes the unlock sequence to $D41F, one byte at a time:
+ *        $F0 → $D41F
+ *        $10 → $D41F
+ *        $63 → $D41F
+ *        $00 → $D41F   (mode = auto)
+ *        $FF → $D41F
+ *    Host reads $D41F and expects:
+ *        - A value >= $E0 AND != $FF.  uSID64 firmware returns $FE; the
+ *          detector accepts anything in [$E0..$FE] as "uSID64 present".
+ *        - $FF = open bus  → not present.
+ *        - < $E0 = NOSID bus decay → not present.
+ *
+ *  Emulation: track the 5-byte unlock sequence; once complete, next D41F
+ *  read returns $FE and then the state resets back to idle (pre-unlock
+ *  reads return $FF open-bus so a probe before the unlock doesn't
+ *  falsely succeed).
+ */
+
+#include "vice.h"
+
+#include <string.h>
+
+#include "sid-variant.h"
+
+typedef struct {
+    uint8_t  step;           /* 0..5 — counts matched bytes of the unlock  */
+} usid64_state_t;
+
+static const uint8_t unlock_seq[5] = { 0xF0, 0x10, 0x63, 0x00, 0xFF };
+
+static usid64_state_t *us(sid_variant_slot_t *slot)
+{
+    return (usid64_state_t *)slot->state;
+}
+
+void sid_variant_usid64_reset(sid_variant_slot_t *slot)
+{
+    memset(slot->state, 0, sizeof(slot->state));
+}
+
+void sid_variant_usid64_observe_write(sid_variant_slot_t *slot,
+                                      uint16_t reg, uint8_t val)
+{
+    usid64_state_t *s = us(slot);
+
+    if (reg != 0x1f) {
+        /* Traffic to other registers doesn't affect the cookie — real chip
+         * has a dedicated state machine gated on $D41F writes. */
+        return;
+    }
+    if (s->step < 5 && val == unlock_seq[s->step]) {
+        s->step++;
+    } else if (val == unlock_seq[0]) {
+        s->step = 1;         /* re-start sequence on fresh $F0 */
+    } else {
+        s->step = 0;         /* mismatch → reset */
+    }
+}
+
+int sid_variant_usid64_try_read(sid_variant_slot_t *slot,
+                                uint16_t reg, uint8_t *out)
+{
+    usid64_state_t *s = us(slot);
+    if (reg != 0x1f) {
+        return 0;
+    }
+    if (s->step >= 5) {
+        *out = 0xFE;           /* uSID64 config-byte answer */
+        s->step = 0;           /* single-shot */
+        return 1;
+    }
+    /* Pre-unlock reads look like open bus so the NOSID-artifact filter
+     * ($FF in siddetector) trips and uSID64 is NOT falsely detected. */
+    *out = 0xFF;
+    return 1;
+}
