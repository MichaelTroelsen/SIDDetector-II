--- /c/Users/mit/Downloads/vice-3.9/src/sid/sid-variant-pdsid.c	1970-01-01 01:00:00.000000000 +0100
+++ vice-sidvariant/src/sid/sid-variant-pdsid.c	2026-04-21 06:25:34.837651700 +0200
@@ -0,0 +1,67 @@
+/** \file   sid-variant-pdsid.c
+ *  \brief  PDsid magic-cookie responder.
+ *
+ *  Protocol (per siddetector.asm `checkpdsid`):
+ *    1. Host writes 'P' ($50) to $D41D.
+ *    2. Host writes 'D' ($44) to $D41E.
+ *    3. Host reads  $D41E and expects to receive 'S' ($53).
+ *
+ *  The responder is stateful: D41E only echoes 'S' if the immediately
+ *  preceding writes were P→$D41D and D→$D41E in that order.  Other traffic
+ *  resets the state machine, matching the real chip's narrow detection
+ *  window.
+ */
+
+#include "vice.h"
+
+#include <string.h>
+
+#include "sid-variant.h"
+
+typedef struct {
+    uint8_t  got_p;          /* 1 once 'P' ($50) has been written to D41D */
+    uint8_t  got_pd;         /* 1 once 'D' ($44) has then been written to D41E */
+} pdsid_state_t;
+
+static pdsid_state_t *ps(sid_variant_slot_t *slot)
+{
+    return (pdsid_state_t *)slot->state;
+}
+
+void sid_variant_pdsid_reset(sid_variant_slot_t *slot)
+{
+    memset(slot->state, 0, sizeof(slot->state));
+}
+
+void sid_variant_pdsid_observe_write(sid_variant_slot_t *slot,
+                                     uint16_t reg, uint8_t val)
+{
+    pdsid_state_t *s = ps(slot);
+
+    if (reg == 0x1d) {
+        s->got_p  = (val == 'P') ? 1 : 0;
+        s->got_pd = 0;
+    } else if (reg == 0x1e) {
+        if (s->got_p && val == 'D') {
+            s->got_pd = 1;
+        } else {
+            s->got_p  = 0;
+            s->got_pd = 0;
+        }
+    }
+    /* Any other register write quietly resets the armed state so a lone
+     * P/D later in the program doesn't leave us stuck in "echo mode". */
+}
+
+int sid_variant_pdsid_try_read(sid_variant_slot_t *slot,
+                               uint16_t reg, uint8_t *out)
+{
+    pdsid_state_t *s = ps(slot);
+    if (reg == 0x1e && s->got_p && s->got_pd) {
+        *out = 'S';              /* magic echo */
+        s->got_p  = 0;           /* single-shot — second read sees open bus */
+        s->got_pd = 0;
+        return 1;
+    }
+    return 0;
+}
