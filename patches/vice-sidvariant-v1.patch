@@ -0,0 +1,80 @@
+/** \file   sid-variant-kungfu.c
+ *  \brief  KungFuSID magic-cookie responder (new-firmware variant only).
+ *
+ *  Protocol (per siddetector.asm `checkkungfusid`):
+ *    1. Host writes $A5 to $D41D.
+ *    2. Host waits ~20 ms.
+ *    3. Host reads  $D41D and expects $5A (new-fw ACK) or $A5 (old-fw echo).
+ *
+ *  siddetector 1.4.x **only** accepts the new-firmware $5A ACK; the old
+ *  $A5-echo path was removed because real SIDs sometimes latch $A5 on the
+ *  bus for long enough to cause false positives.  This module mirrors that:
+ *  the `kungfusid-new` variant responds with $5A, while `kungfusid-old`
+ *  responds with $A5 for legacy-protocol testing.
+ */
+
+#include "vice.h"
+
+#include <string.h>
+
+#include "sid-variant.h"
+
+typedef struct {
+    uint8_t  armed;          /* 1 if $A5 was just written to D41D */
+    uint8_t  last_v3ctrl;    /* last value written to D412 (voice-3 control) */
+} kfs_state_t;
+
+static kfs_state_t *ks(sid_variant_slot_t *slot)
+{
+    return (kfs_state_t *)slot->state;
+}
+
+void sid_variant_kungfu_reset(sid_variant_slot_t *slot)
+{
+    memset(slot->state, 0, sizeof(slot->state));
+}
+
+void sid_variant_kungfu_observe_write(sid_variant_slot_t *slot,
+                                      uint16_t reg, uint8_t val)
+{
+    kfs_state_t *s = ks(slot);
+    if (reg == 0x1d && val == 0xA5) {
+        s->armed = 1;
+    } else if (reg == 0x1d) {
+        s->armed = 0;                        /* other D41D write disarms */
+    }
+    if (reg == 0x12) {
+        s->last_v3ctrl = val;                /* track voice-3 ctrl for D41B poison */
+    }
+}
+
+int sid_variant_kungfu_try_read(sid_variant_slot_t *slot,
+                                uint16_t reg, uint8_t *out)
+{
+    kfs_state_t *s = ks(slot);
+
+    /* D41B (OSC3) readback — real KungFuSID does NOT emulate the SID voice-3
+     * sawtooth timing that `checkrealsid` expects ($00 / $03 / $05..$06 / $08
+     * at specific read phases), so we return 0 and break the sawtooth test
+     * on its 2nd read (`cmp #$03`).  But the mirror-test in `checksecondsid`
+     * writes $81 (noise) to D412 and also reads D41B — there it needs the
+     * noise output to come through ResID so the primary is correctly flagged
+     * as "a real chip".  We distinguish by the last written voice-3 ctrl
+     * value: only poison when sawtooth/pulse is active. */
+    if (reg == 0x1b && s->last_v3ctrl != 0x81) {
+        *out = 0x00;
+        return 1;
+    }
+
+    if (reg != 0x1d || !s->armed) {
+        return 0;
+    }
+    if (slot->kind == SID_VARIANT_KUNGFUSID_NEW) {
+        *out = 0x5A;         /* FW_UPDATE_START_ACK on new firmware */
+    } else {
+        *out = 0xA5;         /* old firmware simply echoes the written magic */
+    }
+    /* Single-shot: further reads see the chip's normal state again. */
+    s->armed = 0;
+    return 1;
+}
