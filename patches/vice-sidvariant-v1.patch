--- /c/Users/mit/Downloads/vice-3.9/src/sid/sid-variant-sidfx.c	1970-01-01 01:00:00.000000000 +0100
+++ vice-sidvariant/src/sid/sid-variant-sidfx.c	2026-04-21 16:43:49.906594800 +0200
@@ -0,0 +1,232 @@
+/** \file   sid-variant-sidfx.c
+ *  \brief  SIDFX magic-cookie responder (SCI protocol + PNP handshake).
+ *
+ *  This is the most elaborate variant module — SIDFX uses a bit-serial
+ *  Serial Control Interface at $D41E (sync) + $D41F (data) instead of a
+ *  simple magic-cookie write pattern.
+ *
+ *  ### Wire protocol (`SCIPUT` / `SCIGET` in siddetector.asm, line ~4858)
+ *
+ *  ```
+ *    ldx #$07      ; 8 bits, MSB first
+ *    stx $D41E     ; sync low (marks start of byte)
+ *  loop:
+ *    pha
+ *    sta $D41F     ; TX bit 7 of tx_byte → chip
+ *    lda $D41F     ; RX bit 0 = received data bit
+ *    ror           ; carry = received bit
+ *    pla
+ *    rol           ; shift tx_byte left, insert received bit
+ *    dex
+ *    bpl loop      ; 8 bit pairs
+ *    stx $D41E     ; sync high (end of byte, x = -1 = $FF)
+ *  ```
+ *
+ *  So each SCI byte is: `$07 → $D41E`, 8× (write TX bit to $D41F, read bit
+ *  from $D41F), `$FF → $D41E`.  Bits are MSB-first in both directions.
+ *
+ *  ### Command sequence (`DETECTSIDFX`, line ~4594)
+ *
+ *  1. 16× `$00` (SCISYN) — bring chip to idle.
+ *  2. `$80`, `$50`, `$4E`, `$50` ("PNP" login).
+ *  3. `$00`, `$00`, `$00`, `$00` (four SCIGET reads).
+ *     Chip responds with vendor/product ID:  `$45`, `$4C`, `$12`, `$58`.
+ *  4. Optional REGUNHIDE (`$C0`, `$45`, `$00`) — control regs D41D/D41E
+ *     become readable and return SW1/SW2/SCAP/PLY and SID1/SID2 model bits.
+ *  5. Optional REGHIDE (`$C1`, `$44`, `$00`) — hide control regs again.
+ *
+ *  ### Default SIDFX configuration exposed to the host
+ *    - `SW1 = 0` (CTR), `SCAP = 1`, `PLY = 0`  →  `D41D = $08`.
+ *    - `SID1 = 6581`, `SID2 = NONE`             →  `D41E = $01`.
+ *  This gives siddetector a clean "SIDFX with one 6581 at D400, no secondary"
+ *  view.  Richer configs (LFT→D420, RGT→DE00, 8580 etc.) can be layered on
+ *  later via a dedicated resource (`SidVariantSidfxSw1="LFT"|"CTR"|"RGT"`).
+ */
+
+#include "vice.h"
+
+#include <string.h>
+
+#include "sid-variant.h"
+
+typedef struct {
+    uint8_t  in_xact;            /* 1 while $07-$FF transaction is active  */
+    uint8_t  bit_idx;            /* 0..7 bits exchanged in current byte    */
+    uint8_t  tx_byte;            /* byte currently arriving from host      */
+    uint8_t  rx_byte;            /* byte currently being shifted out       */
+    uint8_t  cmd_phase;          /* 0=idle, 1..=progress through commands  */
+    uint8_t  unhidden;           /* 1 after REGUNHIDE, 0 after REGHIDE     */
+    uint8_t  d41d_val;           /* SW2/SW1/SCAP/PLY — returned when unhidden */
+    uint8_t  d41e_val;           /* SID2/SID1 — returned when unhidden      */
+    uint8_t  pending_rx[8];      /* queued response bytes after PNP etc.    */
+    uint8_t  rx_head;            /* next byte index to consume from pending_rx */
+    uint8_t  rx_tail;            /* one past last valid byte in pending_rx  */
+} sidfx_state_t;
+
+/* Command-phase constants — position in `cmd_phase` maps 1:1 to the byte
+ * index we *expect* to receive next. */
+#define SFX_PHASE_IDLE          0     /* waiting for $80 PNP prefix       */
+#define SFX_PHASE_GOT_80        1
+#define SFX_PHASE_GOT_80_50     2
+#define SFX_PHASE_GOT_80_50_4E  3
+#define SFX_PHASE_PNP_DONE      4     /* vendor bytes loaded into rx queue */
+#define SFX_PHASE_GOT_C0        10    /* REGUNHIDE first byte             */
+#define SFX_PHASE_GOT_C1        11    /* REGHIDE first byte               */
+
+static sidfx_state_t *fx(sid_variant_slot_t *slot)
+{
+    return (sidfx_state_t *)slot->state;
+}
+
+static void queue_rx(sidfx_state_t *s, const uint8_t *bytes, int n)
+{
+    int i;
+    s->rx_head = 0;
+    s->rx_tail = (uint8_t)n;
+    for (i = 0; i < n && i < (int)sizeof(s->pending_rx); i++) {
+        s->pending_rx[i] = bytes[i];
+    }
+}
+
+static uint8_t pop_rx(sidfx_state_t *s)
+{
+    if (s->rx_head < s->rx_tail) {
+        return s->pending_rx[s->rx_head++];
+    }
+    return 0x00;                 /* idle → $00 */
+}
+
+void sid_variant_sidfx_reset(sid_variant_slot_t *slot)
+{
+    sidfx_state_t *s = fx(slot);
+    memset(s, 0, sizeof(*s));
+    s->d41d_val = 0x08;          /* SW1=0 (CTR), SCAP=1, PLY=0             */
+    s->d41e_val = 0x01;          /* SID1=6581, SID2=NONE                   */
+}
+
+/* Called once per complete SCI byte exchange (when bit_idx reaches 8). */
+static void process_tx_byte(sidfx_state_t *s)
+{
+    uint8_t v = s->tx_byte;
+    static const uint8_t pnp_resp[4] = { 0x45, 0x4C, 0x12, 0x58 };
+
+    switch (s->cmd_phase) {
+    case SFX_PHASE_IDLE:
+        if (v == 0x80) {
+            s->cmd_phase = SFX_PHASE_GOT_80;
+        } else if (v == 0xC0) {
+            s->cmd_phase = SFX_PHASE_GOT_C0;
+        } else if (v == 0xC1) {
+            s->cmd_phase = SFX_PHASE_GOT_C1;
+        }
+        /* other values (incl. $00 SYN) leave us idle */
+        break;
+    case SFX_PHASE_GOT_80:
+        s->cmd_phase = (v == 0x50) ? SFX_PHASE_GOT_80_50 : SFX_PHASE_IDLE;
+        break;
+    case SFX_PHASE_GOT_80_50:
+        s->cmd_phase = (v == 0x4E) ? SFX_PHASE_GOT_80_50_4E : SFX_PHASE_IDLE;
+        break;
+    case SFX_PHASE_GOT_80_50_4E:
+        if (v == 0x50) {
+            s->cmd_phase = SFX_PHASE_PNP_DONE;
+            queue_rx(s, pnp_resp, 4);
+        } else {
+            s->cmd_phase = SFX_PHASE_IDLE;
+        }
+        break;
+    case SFX_PHASE_PNP_DONE:
+        /* 4 SCIGET calls follow — host transmits $00.  After the queue is
+         * drained, drop back to idle so further commands are recognised. */
+        if (s->rx_head >= s->rx_tail) {
+            s->cmd_phase = SFX_PHASE_IDLE;
+        }
+        break;
+    case SFX_PHASE_GOT_C0:
+        if (v == 0x45) {
+            s->unhidden = 1;
+        }
+        s->cmd_phase = SFX_PHASE_IDLE;
+        break;
+    case SFX_PHASE_GOT_C1:
+        if (v == 0x44) {
+            s->unhidden = 0;
+        }
+        s->cmd_phase = SFX_PHASE_IDLE;
+        break;
+    default:
+        s->cmd_phase = SFX_PHASE_IDLE;
+        break;
+    }
+}
+
+static void start_byte(sidfx_state_t *s)
+{
+    s->in_xact = 1;
+    s->bit_idx = 0;
+    s->tx_byte = 0;
+    s->rx_byte = pop_rx(s);
+}
+
+void sid_variant_sidfx_observe_write(sid_variant_slot_t *slot,
+                                     uint16_t reg, uint8_t val)
+{
+    sidfx_state_t *s = fx(slot);
+
+    if (reg == 0x1e) {
+        /* SCI sync signal. */
+        if (val == 0x07) {
+            start_byte(s);
+        } else if (val == 0xFF) {
+            s->in_xact = 0;
+        }
+        /* Other values (e.g. $00 write during detection-unrelated code) —
+         * ignore; we only care about the explicit $07/$FF framing. */
+        return;
+    }
+
+    if (reg == 0x1f && s->in_xact) {
+        /* Host TX bit = bit 7 of the write value.  Accumulate MSB-first. */
+        s->tx_byte = (uint8_t)((s->tx_byte << 1) | (val >> 7));
+        s->bit_idx++;
+        if (s->bit_idx >= 8) {
+            process_tx_byte(s);
+            s->bit_idx = 0;
+            /* Prepare the next rx_byte — the protocol exchanges 8 bits per
+             * SCI call, then SCIPUT continues with the next write+read pair
+             * (bit_idx re-set).  But siddetector's SCIPUT transfers exactly
+             * 8 bits then writes $FF to D41E — we get the next `start_byte`
+             * via $07→D41E.  No work needed here. */
+        }
+        return;
+    }
+}
+
+int sid_variant_sidfx_try_read(sid_variant_slot_t *slot,
+                               uint16_t reg, uint8_t *out)
+{
+    sidfx_state_t *s = fx(slot);
+
+    if (reg == 0x1f && s->in_xact) {
+        /* Emit MSB of current rx_byte as bit 0 of the read value — the only
+         * bit siddetector cares about (ror/rol chain on bit 0). */
+        uint8_t bit = (uint8_t)((s->rx_byte >> 7) & 1);
+        s->rx_byte = (uint8_t)(s->rx_byte << 1);
+        *out = bit;
+        return 1;
+    }
+
+    /* When unhidden, D41D and D41E expose SIDFX config registers. */
+    if (s->unhidden) {
+        if (reg == 0x1d) {
+            *out = s->d41d_val;
+            return 1;
+        }
+        if (reg == 0x1e) {
+            *out = s->d41e_val;
+            return 1;
+        }
+    }
+
+    return 0;
+}
