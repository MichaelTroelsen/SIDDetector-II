+/** \file   sid-variant.h
+ *  \brief  Pluggable SID-chip "personality" layer.
+ *
+ *  This is a thin hook on top of the normal ResID/FastSID emulation that lets
+ *  each emulated SID slot pretend to be a specific third-party chip — ARMSID,
+ *  ARM2SID, SwinSID Ultimate / Nano, FPGASID, PDsid, KungFuSID, BackSID,
+ *  SIDKick-pico, SIDFX, uSID64 — for the purpose of automated *detection*
+ *  testing (siddetector.prg and friends).  Audio is unaffected; only the
+ *  write-only `$D41D/$D41E/$D41F` magic-cookie protocol and adjacent
+ *  `$D41B`/`$D41C` echo reads are intercepted.
+ *
+ *  Runtime selection is per SID chip (0..7) via the `SidVariant`…
+ *  `SidVariant8` resources and the `-sidvariant{,2,3,4,5,6,7,8}` CLI flags.
+ *  Name `"none"` disables the layer entirely for that chip — identical to
+ *  mainline VICE 3.9 behaviour.
+ *
+ *  This header is internal to `src/sid/`.  Only `sid.c` calls the two dispatch
+ *  functions; `sid-resources.c` and `sid-cmdline-options.c` call the
+ *  *_init functions once at startup.
+ */
+
+#ifndef VICE_SID_VARIANT_H
+#define VICE_SID_VARIANT_H
+
+#include "types.h"
+
+/* Matches SOUND_SIDS_MAX in sound.h — 8 concurrent SID chips supported. */
+#define SID_VARIANT_NUM_CHIPS 8
+
+/* Canonical variant kinds.  Strings live in sid-variant.c's name table. */
+typedef enum {
+    SID_VARIANT_NONE = 0,
+    SID_VARIANT_ARMSID,
+    SID_VARIANT_ARM2SID,
+    SID_VARIANT_SWINU,
+    SID_VARIANT_SWINNANO,
+    SID_VARIANT_FPGASID_6581,
+    SID_VARIANT_FPGASID_8580,
+    SID_VARIANT_PDSID,
+    SID_VARIANT_KUNGFUSID_OLD,
+    SID_VARIANT_KUNGFUSID_NEW,
+    SID_VARIANT_BACKSID,
+    SID_VARIANT_SKPICO_8580,
+    SID_VARIANT_SKPICO_6581,
+    SID_VARIANT_SIDFX,
+    SID_VARIANT_USID64,
+    SID_VARIANT_COUNT               /* sentinel */
+} sid_variant_kind_t;
+
+/* Per-chip slot state shared between the dispatcher and each variant module.
+ * `state[]` is a raw byte scratch area; each variant casts it to its own
+ * struct (typedef'd inside that variant's .c file). */
+typedef struct {
+    char               *name;            /* canonical resource string */
+    sid_variant_kind_t  kind;
+    uint8_t             state[64];
+    unsigned long       last_write_clk;
+} sid_variant_slot_t;
+
+/* Shared accessor so per-variant modules can reach the slot state without
+ * each opening the static array in sid-variant.c. */
+sid_variant_slot_t *sid_variant_slot(int chipno);
+
+/** Called from `sid_read_chip()` before the ResID read.
+ *  \return 1 if the variant handled the read (value stored in *out);
+ *          0 if the variant declined and the caller should use the ResID value.
+ */
+int  sid_variant_try_read(int chipno, uint16_t reg, uint8_t *out);
+
+/** Called from `sid_store_chip()` *after* VICE's own register bookkeeping.
+ *  Variants observe every write so they can advance their state machine.
+ */
+void sid_variant_observe_write(int chipno, uint16_t reg, uint8_t val);
+
+/** Called on machine reset — clears all variant state to the chip's idle
+ *  (post-power-on) configuration.
+ */
+void sid_variant_reset_all(void);
+
+/** Register `SidVariant` / `SidVariant2`..`SidVariant8` resources.
+ *  Call from `sid_resources_init()` alongside the stereo resources.
+ */
+int  sid_variant_resources_init(void);
+
+/** Free any runtime memory allocated by the resource setters.
+ *  Call from `sid_resources_shutdown()` (or machine shutdown). */
+void sid_variant_resources_shutdown(void);
+
+/** Register `-sidvariant` / `-sidvariant2`..`-sidvariant8` CLI options.
+ *  Call from `sid_cmdline_options_init()`.
+ */
+int  sid_variant_cmdline_options_init(void);
+
+#endif /* VICE_SID_VARIANT_H */
