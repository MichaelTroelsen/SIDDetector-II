+void sid_variant_resources_shutdown(void)
+{
+    int i;
+    for (i = 0; i < SID_VARIANT_NUM_CHIPS; i++) {
+        if (slots[i].name != NULL) {
+            lib_free(slots[i].name);
+            slots[i].name = NULL;
+        }
+    }
+}
