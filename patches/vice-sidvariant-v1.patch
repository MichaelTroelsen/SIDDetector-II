+++ vice-sidvariant/src/sid/sid-variant-fpgasid.c	2026-04-21 11:22:05.056767900 +0200
@@ -0,0 +1,97 @@
+/** \file   sid-variant-fpgasid.c
+ *  \brief  FPGASID 6581 / 8580 magic-cookie responder.
+ *
+ *  Protocol (per siddetector.asm `checkfpgasid`):
+ *    1. Host writes magic cookie:
+ *         $81 → $D419,    $65 → $D41A         (enter config mode)
+ *         $80 → $D41E                          (identify mode)
+ *    2. Host reads:
+ *         $D419 → expect $1D      (identify byte lo)
+ *         $D41A → expect $F5      (identify byte hi — together forms $F51D)
+ *         $D41E → discarded
+ *         $D41F → $3F = 8580,  $00 = 6581
+ *    3. Host exits: $00 → $D419, $00 → $D41A
+ *
+ *  Two kind values select the mode: `fpgasid8580` returns $3F, `fpgasid6581`
+ *  returns $00.  State machine is deliberately narrow — only the exact
+ *  cookie sequence flips us into "identify" mode; any other writes drop back
+ *  to idle so unrelated SID traffic doesn't leave us mistakenly armed.
+ */
+
+#include "vice.h"
+
+#include <string.h>
+
+#include "sid-variant.h"
+
+typedef struct {
+    uint8_t  cookie_lo;      /* last write to D419 */
+    uint8_t  cookie_hi;      /* last write to D41A */
+    uint8_t  identify;       /* 1 after $80 → D41E while cookie valid */
+} fpga_state_t;
+
+static fpga_state_t *fp(sid_variant_slot_t *slot)
+{
+    return (fpga_state_t *)slot->state;
+}
+
+void sid_variant_fpgasid_reset(sid_variant_slot_t *slot)
+{
+    memset(slot->state, 0, sizeof(slot->state));
+}
+
+void sid_variant_fpgasid_observe_write(sid_variant_slot_t *slot,
+                                       uint16_t reg, uint8_t val)
+{
+    fpga_state_t *s = fp(slot);
+
+    switch (reg) {
+    case 0x19:
+        s->cookie_lo = val;
+        if (val == 0x00) {
+            s->identify = 0;                  /* exit config */
+        }
+        break;
+    case 0x1a:
+        s->cookie_hi = val;
+        if (val == 0x00) {
+            s->identify = 0;
+        }
+        break;
+    case 0x1e:
+        if (val == 0x80
+            && s->cookie_lo == 0x81
+            && s->cookie_hi == 0x65) {
+            s->identify = 1;                  /* $F51D now readable */
+        }
+        break;
+    default:
+        break;
+    }
+}
+
+int sid_variant_fpgasid_try_read(sid_variant_slot_t *slot,
+                                 uint16_t reg, uint8_t *out)
+{
+    fpga_state_t *s = fp(slot);
+
+    if (!s->identify) {
+        return 0;
+    }
+    switch (reg) {
+    case 0x19:
+        *out = 0x1D;                          /* identify byte 0 */
+        return 1;
+    case 0x1a:
+        *out = 0xF5;                          /* identify byte 1 */
+        return 1;
+    case 0x1e:
+        *out = 0x00;                          /* read discarded by detector */
+        return 1;
+    case 0x1f:
+        *out = (slot->kind == SID_VARIANT_FPGASID_8580) ? 0x3F : 0x00;
+        return 1;
+    default:
+        return 0;
+    }
+}
