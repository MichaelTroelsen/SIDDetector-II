@@ -0,0 +1,147 @@
+/** \file   sid-variant-skpico.c
+ *  \brief  SIDKick-pico magic-cookie responder.
+ *
+ *  Three-phase protocol (per siddetector.asm `checkskpico`):
+ *
+ *  Phase 1 — identity
+ *      $FF → $D41F               (enter config mode)
+ *      $E0 → $D41E               (set byte pointer to 0)
+ *      read $D41D → 'S' ($53)
+ *      $E1 → $D41E               (advance pointer)
+ *      read $D41D → 'K' ($4B)
+ *
+ *  Phase 2 — model detection  (exits config mode first)
+ *      $00 → $D418               (non-config-reg write → leave config mode)
+ *      $FF → $D40E, $D40F, $D412 (preconditions)
+ *      $20 → $D412               (REG_AUTO_DETECT_STEP = 1 trigger)
+ *      read $D41B → 2 (8580) / 3 (6581)
+ *      $00 → $D412               (stop waveform)
+ *
+ *  Phase 3 — FM / CFG_SID2_TYPE readback (only if 8580 was detected)
+ *      $FF → $D41F               (re-enter config mode)
+ *      $00 → $D41E               (page 0, starting at config[0])
+ *      read $D41D  × 9           (first 8 discarded, 9th = CFG_SID2_TYPE)
+ *
+ *  State tracking:
+ *    - `cfg_mode` flips on $FF→D41F and clears on any non-config-reg write
+ *      (siddetector uses $00→D418 for that).
+ *    - `ptr` holds the current config-page byte pointer ($00..$FF).  Reads
+ *      of $D41D in config mode return the byte at `ptr` then advance it.
+ *    - Auto-detect sequence: track the last three D412 writes.  When the
+ *      pattern ( $FF , $FF , $20 ) is seen in rapid succession with
+ *      D40E=$FF and D40F=$FF, the next D41B read returns the model byte.
+ */
+
+#include "vice.h"
+
+#include <string.h>
+
+#include "sid-variant.h"
+
+typedef struct {
+    uint8_t  cfg_mode;         /* 1 while in config mode */
+    uint8_t  ptr;              /* current config byte pointer */
+    uint8_t  d40e;             /* last D40E write (precondition track) */
+    uint8_t  d40f;             /* last D40F write */
+    uint8_t  d412_prev;        /* D412 write trace for auto-detect trigger */
+    uint8_t  d412;             /* most recent D412 write */
+    uint8_t  autodetect_armed; /* 1 when the FF,FF,FF,20 pattern has been seen */
+} skpico_state_t;
+
+static skpico_state_t *sk(sid_variant_slot_t *slot)
+{
+    return (skpico_state_t *)slot->state;
+}
+
+void sid_variant_skpico_reset(sid_variant_slot_t *slot)
+{
+    memset(slot->state, 0, sizeof(slot->state));
+}
+
+void sid_variant_skpico_observe_write(sid_variant_slot_t *slot,
+                                      uint16_t reg, uint8_t val)
+{
+    skpico_state_t *s = sk(slot);
+
+    switch (reg) {
+    case 0x0e:
+        s->d40e = val;
+        break;
+    case 0x0f:
+        s->d40f = val;
+        break;
+    case 0x12:
+        /* Auto-detect trigger:  previous writes were D40E=$FF, D40F=$FF, then
+         * D412 goes $FF → $FF → $20.  Arm when that happens. */
+        s->d412_prev = s->d412;
+        s->d412      = val;
+        if (val == 0x20
+            && s->d412_prev == 0xFF
+            && s->d40e == 0xFF
+            && s->d40f == 0xFF) {
+            s->autodetect_armed = 1;
+        } else if (val == 0x00) {
+            s->autodetect_armed = 0;        /* D412=$00 stops waveform */
+        }
+        break;
+    case 0x18:
+        /* Writing anything to D418 leaves config mode (detector uses $00). */
+        s->cfg_mode = 0;
+        break;
+    case 0x1e:
+        /* Config-mode pointer set / advance. */
+        if (s->cfg_mode) {
+            s->ptr = val;
+        }
+        break;
+    case 0x1f:
+        if (val == 0xFF) {
+            s->cfg_mode = 1;
+            /* leave ptr alone — detector will set it next via D41E */
+        }
+        break;
+    default:
+        break;
+    }
+}
+
+int sid_variant_skpico_try_read(sid_variant_slot_t *slot,
+                                uint16_t reg, uint8_t *out)
+{
+    skpico_state_t *s = sk(slot);
+
+    if (reg == 0x1b && s->autodetect_armed) {
+        /* model detect:  2 = 8580, 3 = 6581 */
+        *out = (slot->kind == SID_VARIANT_SKPICO_8580) ? 0x02 : 0x03;
+        /* Single-shot — consumed by the detector; siddetector writes $00 to
+         * D412 immediately after, which our observer already clears. */
+        s->autodetect_armed = 0;
+        return 1;
+    }
+
+    if (reg == 0x1d && s->cfg_mode) {
+        uint8_t v = 0x00;
+        switch (s->ptr) {
+        case 0xE0:  v = 'S';  break;    /* VERSION_STR[0] = 'S' */
+        case 0xE1:  v = 'K';  break;    /* VERSION_STR[1] = 'K' */
+        case 0xE2:  v = 'I';  break;    /* plausible defaults for Phase-3 ignored bytes */
+        case 0xE3:  v = 'D';  break;
+        case 0xE4:  v = 'P';  break;
+        case 0xE5:  v = 'I';  break;
+        case 0xE6:  v = 'C';  break;
+        case 0xE7:  v = 'O';  break;
+        /* Page-0 config reads (Phase 3) — detector reads 9 bytes.  We just
+         * return 0 for config[0..7]; config[8] = CFG_SID2_TYPE = 0 means
+         * "no secondary / no FM", which is the safe default. */
+        default:
+            v = 0x00;
+            break;
+        }
+        *out = v;
+        /* Auto-increment the pointer on each read, matching the real chip. */
+        s->ptr = (uint8_t)(s->ptr + 1);
+        return 1;
+    }
+
+    return 0;
+}
