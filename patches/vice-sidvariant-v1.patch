+/** \file   sid-variant-backsid.c
+ *  \brief  BackSID magic-cookie responder.
+ *
+ *  Protocol (per siddetector.asm `checkbacksid`):
+ *    Pre-check:
+ *      Cold read $D41F — must NOT return $01 (any other value is fine).
+ *    Unlock sequence:
+ *      Write $02 → $D41B           (voice-3 OSC3 readback register; write as probe)
+ *      Write $01 → $D41C           (echo value — what D41F returns after unlock)
+ *      Write $B5 → $D41D           (unlock key 1)
+ *      Write $1D → $D41E           (unlock key 2)
+ *    Poll loop (15× with ~42 ms between reads):
+ *      Write $02 → $D41B each iteration (keeps the latch armed)
+ *      Read  $D41F  — real BackSID returns $01 once the unlock is complete.
+ *
+ *  Emulation behaviour:
+ *    - Before any writes we return $00 for the pre-check ($00 is not $01 so
+ *      it passes the siddetector pre-check).
+ *    - On seeing B5→D41D and 1D→D41E (after 02→D41B and 01→D41C) we transition
+ *      to "unlocked" and subsequent D41F reads return $01.
+ *    - A fresh machine reset or a non-matching write sequence clears state.
+ */
+
+#include "vice.h"
+
+#include <string.h>
+
+#include "sid-variant.h"
+
+typedef struct {
+    uint8_t  step;           /* 0=idle, 1=got 02→D41B, 2=got 01→D41C, 3=got B5→D41D, 4=unlocked */
+    uint8_t  echo;           /* value stored from D41C (normally $01)               */
+    uint8_t  armed;          /* re-armed by write of $02 to D41B during poll        */
+} backsid_state_t;
+
+static backsid_state_t *bs(sid_variant_slot_t *slot)
+{
+    return (backsid_state_t *)slot->state;
+}
+
+void sid_variant_backsid_reset(sid_variant_slot_t *slot)
+{
+    memset(slot->state, 0, sizeof(slot->state));
+}
+
+void sid_variant_backsid_observe_write(sid_variant_slot_t *slot,
+                                       uint16_t reg, uint8_t val)
+{
+    backsid_state_t *s = bs(slot);
+
+    switch (reg) {
+    case 0x1b:                                  /* probe / re-arm */
+        if (val == 0x02) {
+            if (s->step == 0) {
+                s->step = 1;                    /* begin sequence */
+            }
+            s->armed = 1;                       /* also the poll re-arm */
+        }
+        break;
+
+    case 0x1c:                                  /* echo value */
+        if (s->step == 1 && val == 0x01) {
+            s->echo = val;
+            s->step = 2;
+        } else {
+            s->step = 0;
+        }
+        break;
+
+    case 0x1d:                                  /* unlock key 1 */
+        if (s->step == 2 && val == 0xB5) {
+            s->step = 3;
+        } else {
+            s->step = 0;
+        }
+        break;
+
+    case 0x1e:                                  /* unlock key 2 */
+        if (s->step == 3 && val == 0x1D) {
+            s->step = 4;                        /* unlocked */
+        } else {
+            s->step = 0;
+        }
+        break;
+
+    default:
+        /* Other writes (especially D418 volume) leave the state alone — the
+         * real BackSID unlock survives normal SID traffic. */
+        break;
+    }
+}
+
+int sid_variant_backsid_try_read(sid_variant_slot_t *slot,
+                                 uint16_t reg, uint8_t *out)
+{
+    backsid_state_t *s = bs(slot);
+
+    if (reg != 0x1f) {
+        return 0;
+    }
+    if (s->step >= 4 && s->armed) {
+        *out = s->echo;                         /* typically $01 */
+        return 1;
+    }
+    /* Pre-check: must not be $01.  Return $00 which is safely != $01. */
+    *out = 0x00;
+    return 1;
+}
